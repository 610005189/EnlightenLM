# EnlightenLM 自定义配置示例
# 复制此文件并修改为您需要的配置

enlighten:
  mode: "custom"  # 或指定 preset: full | balanced | lightweight
  description: "自定义配置"

  components:
    van_stream:
      level: "medium"  # light | medium | full
      van_threshold: 0.85
      sensitive_keywords:
        - "暴力"
        - "犯罪"
        - "自定义关键词"

    gate_fusion:
      enabled: true
      fusion_threshold: 0.6

    dmn_noise:
      enabled: true
      noise_strength: 0.05

    working_memory:
      capacity: 384  # 自定义容量
      refresh_interval: 16  # 自定义刷新间隔
      use_topk_refresh: true
      embedding_dim: 768

    entropy_monitor:
      window_size: 15
      alert_threshold: 0.35

    cutoff:
      low_entropy_threshold: 0.45
      low_variance_threshold: 0.08
      min_duration: 3
      cooldown_steps: 8
      flicker_window_size: 4
      flicker_threshold: 0.55

    async_review:
      enabled: true
      model: "deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B"
      interval: 16
      queue_size: 50

  performance:
    target_latency_overhead: 0.12
    target_memory_overhead_gb: 1.2
    target_repetition_rate: 0.025

  logging:
    level: "DEBUG"
    log_decisions: true
    log_history_size: 500