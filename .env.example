# =============================================================================
# EnlightenLM 环境变量配置
# 复制此文件为 .env 并填入实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 配置文件路径
# -----------------------------------------------------------------------------
# 配置文件路径（可选，不设置则使用默认预设）
ENLIGHTEN_CONFIG_PATH=configs/balanced.yaml

# 运行模式: full, balanced, lightweight
# 注意：如果设置了ENLIGHTEN_CONFIG_PATH，此项会被配置文件中的设置覆盖
ENLIGHTEN_MODE=balanced

# -----------------------------------------------------------------------------
# API 配置
# -----------------------------------------------------------------------------
# DeepSeek API Key (必需 - API模式)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# -----------------------------------------------------------------------------
# 模型配置
# -----------------------------------------------------------------------------
# 是否使用本地模型 (true/false)
ENLIGHTEN_MODEL_USE_LOCAL=false

# 本地模型名称 (HuggingFace模型名)
ENLIGHTEN_MODEL_LOCAL_NAME=Qwen/Qwen2-7B

# API提供者: ollama, deepseek
ENLIGHTEN_MODEL_API_PROVIDER=ollama

# API模型名称
ENLIGHTEN_MODEL_API_MODEL=qwen2.5:14b

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# GPU配置
# -----------------------------------------------------------------------------
# NVIDIA GPU设备ID (留空使用所有GPU)
CUDA_VISIBLE_DEVICES=0

# -----------------------------------------------------------------------------
# 监控配置 (生产环境)
# -----------------------------------------------------------------------------
# Grafana admin密码
GRAFANA_PASSWORD=admin

# Prometheus端口
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Redis配置 (生产环境)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=